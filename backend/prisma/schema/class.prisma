model Class {
  id            Int              @id @default(autoincrement())
  name          String           @unique
  capacity      Int
  grade         Int
  supervisor    String

  students      Student[]
  teachers      TeacherClass[]

  lessons       Lesson[]
  exams         Exam[]
  assignments   Assignment[]
  results       Result[]
  events        Event[]
  announcements Announcement[]

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}