  generator client {
  provider = "prisma-client-js"
}

  datasource db {
    provider = "postgresql"
  }

  enum Role {
    ADMIN
    TEACHER
    STUDENT
    PARENT
  }

  model User {
    id        String   @id @default(cuid())
    name      String
    email     String   @unique
    password  String
    role      Role
    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
  }
